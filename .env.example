# Stock God Evidence Engine v6 environment template
# Phase 0 does not require external API keys.

# Future EDGAR integration should identify the app with a compliant user agent.
STOCKGOD_EDGAR_USER_AGENT=""

# Future market-data provider keys can be added here when specified by the source-of-truth docs.
STOCKGOD_MARKET_DATA_API_KEY=""

# Phase 4A read-only provider configuration
MARKET_DATA_PROVIDER=massive
MASSIVE_API_KEY=

FUNDAMENTALS_PROVIDER=fmp
FMP_API_KEY=

EARNINGS_PROVIDER=fmp
NEWS_PROVIDER=fmp
INSIDER_DISCOVERY_PROVIDER=fmp
INSIDER_VERIFICATION_PROVIDER=sec_edgar

FRED_API_KEY=
SEC_USER_AGENT="Michael StockGod your_email@example.com"

YAHOO_FALLBACK_ENABLED=true

OUTPUT_DIR=reports
STATE_PATH=data/state/scans.json
JOURNAL_PATH=data/state/decision_journal.json
MODEL_VERSION=v6.0

# Opt-in only: enables live read-only provider smoke tests when real keys are configured.
RUN_LIVE_PROVIDER_SMOKE=0
